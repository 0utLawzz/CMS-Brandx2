modules = ["nodejs-20"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Expo (Android)"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start API (MySQL)"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node server.js"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Start Expo (Android)"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd mobile && EXPO_NO_DOTENV=1 npx expo start --tunnel --port 8081"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Start API (MySQL)"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd api && node index.js"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[deployment]
deploymentTarget = "autoscale"
run = ["node", "server.js"]
